# Build artifacts (the whole workspace shares one root target dir)
/target
# The dev tools under tools/ are separate workspaces with their own build dirs
tools/*/target/

# rustfmt backups
**/*.rs.bk

# MSVC debug info
*.pdb

# Local environment and secrets: never commit real account credentials
.env
.env.*

# Offline signing key for the runner catalog: the private seed stays on the maintainer's machine
/.catalog-signing/

# Corpus cache: boot patches fetched by URL+SHA256 on demand, keyed by digest, never checked in
/.corpus-cache/

# OS cruft
.DS_Store

# Editor and IDE files
/.idea/
/.vscode/
*.swp
*~
