# Build artifacts (the whole workspace shares one root target dir)
/target

# rustfmt backups
**/*.rs.bk

# MSVC debug info
*.pdb

# Local environment and secrets: never commit real account credentials
.env
.env.*

# Offline signing key for the runner catalog: the private seed stays on the maintainer's machine
/.catalog-signing/

# OS cruft
.DS_Store

# Editor and IDE files
/.idea/
/.vscode/
*.swp
*~
